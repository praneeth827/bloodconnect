# Server Configuration
PORT=3001

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production

# Session Secret (generate a strong random string)
SESSION_SECRET=your_session_secret_key_here_change_this_in_production

# Google OAuth Configuration (Optional)
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Google Maps API Key (Optional - for map features)
# Get this from Google Cloud Console: https://console.cloud.google.com/
# Enable: Maps JavaScript API and Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# SMTP configuration for email notifications (Optional)
# These are used by the Nodemailer-based email service to notify nearby donors.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
# Set to "true" if using port 465 / SSL
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="BloodConnect <no-reply@yourdomain.com>"

# Optional email tuning
# Maximum radius (km) within which donors receive email alerts from POST /api/donors/search
NOTIFY_RADIUS_KM=10
# Maximum number of donors to email per search
MAX_EMAILS_PER_SEARCH=25
# Concurrency for sending email batches
DONOR_NOTIFY_CONCURRENCY=6

# Optional: banner image to embed in urgent blood emails (relative to project root or absolute path)
EMAIL_BANNER_PATH=assets/email-banner.png
